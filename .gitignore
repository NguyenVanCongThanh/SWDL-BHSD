__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# IDE/Editor configurations
.idea/
.vscode/

# Compressed/archive files
*.zip
*.tar.gz
*.rar

# OS files
.DS_Store
Thumbs.db
